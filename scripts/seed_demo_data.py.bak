    # Your scanner targets 192.168.0.0/24. Offset by 150 to land in
    # .151-.170, clear of router (.1), phone (.100), laptop (.101).
    return f"192.168.0.{host_octet + 150}"


def random_mac() -> str:
    return ":".join(f"{random.randint(0, 255):02x}" for _ in range(6))


def build_assets(session):
    """
    20 assets with a guaranteed spread of criticality so every tier
    (Low/Medium/High) is always reachable by at least a few assets.
    """
    criticalities = (
        [random.randint(1, 3) for _ in range(7)] +   # low-value assets
        [random.randint(4, 6) for _ in range(7)] +   # mid-value assets
        [random.randint(7, 10) for _ in range(6)]    # high-value assets
    )
    random.shuffle(criticalities)

    assets = []
    for i, criticality in enumerate(criticalities, start=1):
        asset = Asset(
            ip_address=random_ip(i),
            hostname=f"host-{i:02d}",
            mac_address=random_mac(),
            open_ports=random.choice(["22,80", "3389", "3306,80,443", "80", "1433,22"]),
            os_type=random.choice(OS_TYPES),
            criticality_score=criticality,
            last_seen=datetime.now(UTC)- timedelta(minutes=random.randint(1, 120)),
        )
        session.add(asset)
        assets.append(asset)
    session.flush()  # populate asset.id before commit
    return assets


def build_alert(session, asset, target_tier):
    sev_range = severity_range_for_tier(asset.criticality_score, target_tier)
    severity = random.randint(*sev_range)

    threat = ThreatRecord(
        ip_address=asset.ip_address,
        source_api=random.choice(THREAT_SOURCES),
        severity_score=severity,
        details_json="{}",
        queried_at=datetime.now(UTC)- timedelta(minutes=random.randint(1, 60)),
    )
    session.add(threat)
    session.flush()

    composite = max(1, min(100, round(asset.criticality_score * severity)))
    acknowledged = random.random() < 0.4
    created = datetime.now(UTC)- timedelta(minutes=random.randint(1, 180))

    risk_alert = RiskAlert(
        asset_ip=asset.ip_address,
        asset_id=asset.id,
        threat_record_id=threat.id,
        asset_criticality=asset.criticality_score,
        threat_severity=severity,
