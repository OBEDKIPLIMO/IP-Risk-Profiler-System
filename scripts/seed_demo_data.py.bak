    """
    Given an asset's criticality, return the (min, max) severity values
    (each 1-10) that would land composite = criticality * severity inside
    the target tier's band. Returns None if no severity value works
    (e.g. a low-criticality asset can never reach "High").
    """
    lo, hi = TIER_BOUNDS[tier]
    sev_lo = max(1, math.ceil(lo / criticality))
    sev_hi = min(10, math.floor(hi / criticality))
    if sev_lo > sev_hi:
        return None
    return sev_lo, sev_hi


