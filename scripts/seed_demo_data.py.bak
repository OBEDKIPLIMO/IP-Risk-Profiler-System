        created_at=created,
        updated_at=created,
    )
    session.add(risk_alert)


def pick_asset_for_tier(assets, tier):
    eligible = [a for a in assets if severity_range_for_tier(a.criticality_score, tier)]
    return random.choice(eligible)


# --------------------------------------------------------------------------
# Session handling — works whether get_session() is a context manager
# (has __enter__/__exit__) or returns a plain Session object.
# --------------------------------------------------------------------------

@contextmanager
def session_scope():
    raw = get_session()

    if hasattr(raw, "__enter__") and hasattr(raw, "__exit__"):
        with raw as session:
            try:
                yield session
                session.commit()
            except Exception:
                session.rollback()
                raise
    else:
        session = raw
        try:
            yield session
            print(">>> About to COMMIT")
            session.commit()
            print(">>> COMMIT succeeded")
        except Exception as e:
            print(">>> EXCEPTION OCCURRED")
            traceback.print_exc()
            session.rollback()
            raise
        finally:
            print(">>> Closing session")
            session.close()
# --------------------------------------------------------------------------
# Safety guard
# --------------------------------------------------------------------------

def describe_target_db(session) -> str:
    """Best-effort human-readable description of the DB about to be wiped."""
    try:
        url = session.get_bind().url
        return str(url)
    except Exception:
        return "<unable to determine database URL>"


def looks_like_safe_db(db_description: str) -> bool:
    lowered = db_description.lower()
    return any(hint in lowered for hint in SAFE_DB_HINTS)


def confirm_wipe(db_description: str, force: bool) -> None:
    """
    Refuses to proceed unless the target DB looks like a dev/demo DB, or
    --force/--yes was passed. Always shows the operator exactly what is
    about to be wiped.
    """
    print(f"Target database: {db_description}")

    if force:
        print("--force/--yes supplied — skipping confirmation.")
        return

    if not looks_like_safe_db(db_description):
        print(
            "\nRefusing to run: this database does not look like a dev/demo/test "
            "database (no 'dev', 'demo', 'test', or ':memory:' in its URL).\n"
            "This script WIPES the Asset, ThreatRecord, and RiskAlert tables.\n"
            "If you're certain this is the right target, re-run with --force.",
            file=sys.stderr,
        )
        sys.exit(1)

    answer = input(
        "\nThis will DELETE all existing Asset, ThreatRecord, and RiskAlert "
        "rows in the database above and replace them with demo data.\n"
        "Type 'yes' to continue: "
    ).strip().lower()
    if answer != "yes":
        print("Aborted — no changes made.")
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(description="Seed demo data for the IP Risk Profiler dashboard.")
    parser.add_argument("--seed", type=int, default=None, help="Random seed for reproducible demo data.")
    parser.add_argument(
        "--force", "-y", "--yes", dest="force", action="store_true",
        help="Skip the confirmation prompt and safety check (use with care).",
    )
    args = parser.parse_args()

    if args.seed is not None:
        random.seed(args.seed)

    with session_scope() as session:
        db_description = describe_target_db(session)
        confirm_wipe(db_description, args.force)

        # Wipe demo tables first (children before parents to respect FKs).
        # Not committed yet — stays part of the same transaction as the
        # reseed below, so a failure rolls back to the original state
        # instead of leaving the tables empty.
        session.query(RiskAlert).delete()
        session.query(ThreatRecord).delete()
        session.query(Asset).delete()

        assets = build_assets(session)

        tiers = ["Low"] * 10 + ["Medium"] * 10 + ["High"] * 10
        random.shuffle(tiers)

        for tier in tiers:
            asset = pick_asset_for_tier(assets, tier)
            build_alert(session, asset, tier)

    print("Demo dataset created: 20 assets, 30 alerts (10 Low / 10 Medium / 10 High).")


if __name__ == "__main__":
    main()
